#!/bin/bash

set -ex
set -o pipefail

apply_imagecache() {
  local name="$1"      # ImageCache resource name (and the kubectl handle)
  local namespace="$2" # target workload namespace (informational; ImageCache lives in kube-fledged)
  local manifest="$3"  # path to the deployment YAML
  local container="$4" # container name inside .spec.template.spec.containers

  local image
  image="$(yq eval ".spec.template.spec.containers[] | select(.name == \"${container}\") | .image" "${manifest}")"
  if [[ -z "${image}" || "${image}" == "null" ]]; then
    echo "apply_imagecache: could not extract image for container=${container} from ${manifest}" >&2
    return 1
  fi

  kubectl apply -f - <<EOF
apiVersion: kubefledged.io/v1alpha2
kind: ImageCache
metadata:
  name: ${name}
  namespace: kube-fledged
spec:
  cacheSpec:
    - images:
        - "${image}"
EOF
}

if [[ "${SKIP_CACHE:-0}" != "1" ]]; then
  # --- kube-fledged: install + wait -------------------------------------
  kustomize build \
    --enable-alpha-plugins \
    --enable-exec \
    kube-fledged \
  | kubectl apply -f -

  kubectl wait --for=condition=Established \
    crd/imagecaches.kubefledged.io --timeout=60s

  kubectl rollout status -n kube-fledged \
    deployment/kubefledged-controller --timeout=2m

  apply_imagecache prometheus monitoring monitoring/prometheus-deployment.yaml prometheus

  kubectl wait --for=jsonpath='{.status.status}'=Succeeded \
    imagecache/prometheus -n kube-fledged --timeout=10m
  # ----------------------------------------------------------------------
else
  echo "SKIP_CACHE=1 — skipping kube-fledged install + image warm"
fi

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  radicale \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  homepage-rb/overlays/prod \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  homepage/overlays/prod \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  grafana \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  monitoring \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  influxdb \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  diun \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  longhorn \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  seaweedfs \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  cert-manager \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  traefik \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  qbt \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  hass \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  calibre-web \
| kubectl apply -f -
