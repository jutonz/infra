#!/bin/bash

set -ex
set -o pipefail

# Images to pre-pull via kube-fledged before applying workload manifests.
# Format: name|namespace|manifest|container
IMAGES=(
  "prometheus|monitoring|monitoring/prometheus-deployment.yaml|prometheus"
  "seaweedfs|seaweedfs|seaweedfs/filer-deployment.yaml|filer"
)

apply_imagecache_crd() {
  local name="$1"      # base name; the ImageCache is named ${namespace}-${name}
  local namespace="$2" # target workload namespace (used to disambiguate ImageCache names)
  local manifest="$3"  # path to the deployment YAML
  local container="$4" # container name inside .spec.template.spec.containers

  local image
  image="$(yq eval ".spec.template.spec.containers[] | select(.name == \"${container}\") | .image" "${manifest}")"
  if [[ -z "${image}" || "${image}" == "null" ]]; then
    echo "apply_imagecache_crd: could not extract image for container=${container} from ${manifest}" >&2
    return 1
  fi

  local cache_name="${namespace}-${name}"

  kubectl apply -f - <<EOF
apiVersion: kubefledged.io/v1alpha2
kind: ImageCache
metadata:
  name: ${cache_name}
  namespace: kube-fledged
spec:
  cacheSpec:
    - images:
        - "${image}"
EOF

  # Force a fresh reconcile via the refresh-imagecache annotation.
  # kube-fledged enqueues a refresh on the absent->present transition
  # and clears the annotation once Processing->Succeeded completes, so
  # polling for "annotation absent AND status=Succeeded" guarantees we
  # observe the reconcile that ran against the spec we just applied
  # (avoids the TOCTOU where `kubectl wait` reads the prior generation's
  # stale Succeeded status). The pre-remove handles a partial prior run
  # that left the annotation in place.
  kubectl annotate imagecache "${cache_name}" -n kube-fledged \
    kubefledged.io/refresh-imagecache- 2>/dev/null || true
  kubectl annotate imagecache "${cache_name}" -n kube-fledged \
    kubefledged.io/refresh-imagecache=
}

watch_imagecache() {
  local namespace="$1" # workload namespace (used in cache_name)
  local name="$2"      # base name

  local cache_name="${namespace}-${name}"

  local deadline=$((SECONDS + 600))
  while (( SECONDS < deadline )); do
    local refresh status
    refresh="$(kubectl get imagecache "${cache_name}" -n kube-fledged \
      -o jsonpath='{.metadata.annotations.kubefledged\.io/refresh-imagecache}' 2>/dev/null || true)"
    status="$(kubectl get imagecache "${cache_name}" -n kube-fledged \
      -o jsonpath='{.status.status}' 2>/dev/null || true)"
    if [[ -z "${refresh}" && "${status}" == "Succeeded" ]]; then
      return 0
    fi
    if [[ -z "${refresh}" && "${status}" == "Failed" ]]; then
      echo "watch_imagecache: ${cache_name} reconcile failed" >&2
      return 1
    fi
    sleep 5
  done
  echo "watch_imagecache: timed out waiting for ${cache_name}" >&2
  return 1
}

if [[ "${SKIP_CACHE:-0}" != "1" ]]; then
  command -v gum >/dev/null || { echo "gum required: brew install gum" >&2; exit 1; }

  # --- kube-fledged: install + wait -------------------------------------
  kustomize build \
    --enable-alpha-plugins \
    --enable-exec \
    kube-fledged \
  | kubectl apply -f -

  kubectl wait --for=condition=Established \
    crd/imagecaches.kubefledged.io --timeout=60s

  kubectl rollout status -n kube-fledged \
    deployment/kubefledged-controller --timeout=2m

  set +x
  applied=()
  for entry in "${IMAGES[@]}"; do
    IFS='|' read -r name namespace manifest container <<< "${entry}"
    apply_imagecache_crd "${name}" "${namespace}" "${manifest}" "${container}"
    applied+=("${name}")
  done
  echo "applied ${#applied[@]} ImageCache CRDs ($(IFS=, ; echo "${applied[*]}"))"

  # Phase B — parallel watch, one gum spinner per image.
  # results_dir holds one $name.ok or $name.fail file per image, written
  # by each background watch job with the elapsed seconds inside.
  results_dir="$(mktemp -d)"
  trap 'rm -rf "${results_dir}"' EXIT

  declare -a PIDS
  declare -a NAMES
  start_ts=${SECONDS}

  for entry in "${IMAGES[@]}"; do
    IFS='|' read -r name namespace manifest container <<< "${entry}"
    image_ref="$(yq eval ".spec.template.spec.containers[] | select(.name == \"${container}\") | .image" "${manifest}")"

    (
      job_start=${SECONDS}
      if watch_imagecache "${namespace}" "${name}" >/dev/null 2>&1; then
        echo "$((SECONDS - job_start))" > "${results_dir}/${name}.ok"
      else
        echo "$((SECONDS - job_start))" > "${results_dir}/${name}.fail"
      fi
    ) &
    watcher_pid=$!

    gum spin --spinner dot --title "${name}  ${image_ref}" -- \
      bash -c "while kill -0 ${watcher_pid} 2>/dev/null; do sleep 1; done" &
    PIDS+=("${watcher_pid}")
    NAMES+=("${name}")
  done

  # Wait for every background watcher and render its result line.
  failed=0
  for i in "${!PIDS[@]}"; do
    pid="${PIDS[$i]}"
    name="${NAMES[$i]}"
    wait "${pid}" || true
    if [[ -f "${results_dir}/${name}.ok" ]]; then
      elapsed="$(cat "${results_dir}/${name}.ok")"
      gum style --foreground 2 "✓ ${name} cached (${elapsed}s)"
    else
      elapsed="$(cat "${results_dir}/${name}.fail" 2>/dev/null || echo "?")"
      gum style --foreground 1 "✗ ${name} failed (${elapsed}s)"
      failed=$((failed + 1))
    fi
  done

  total_elapsed=$((SECONDS - start_ts))
  succeeded=$(( ${#PIDS[@]} - failed ))

  summary_lines=("image-cache: ${succeeded}/${#PIDS[@]} cached in ${total_elapsed}s")
  for i in "${!PIDS[@]}"; do
    name="${NAMES[$i]}"
    if [[ -f "${results_dir}/${name}.ok" ]]; then
      elapsed="$(cat "${results_dir}/${name}.ok")"
      summary_lines+=("  ${name}  cached  ${elapsed}s")
    else
      elapsed="$(cat "${results_dir}/${name}.fail" 2>/dev/null || echo "?")"
      summary_lines+=("  ${name}  FAILED  ${elapsed}s")
    fi
  done
  printf '%s\n' "${summary_lines[@]}" | gum style --border normal --padding "0 1"

  if (( failed > 0 )); then
    exit 1
  fi
  set -x
  # ----------------------------------------------------------------------
else
  echo "SKIP_CACHE=1 — skipping kube-fledged install + image warm"
fi

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  radicale \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  homepage-rb/overlays/prod \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  homepage/overlays/prod \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  grafana \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  monitoring \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  influxdb \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  diun \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  longhorn \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  seaweedfs \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  cert-manager \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  traefik \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  qbt \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  hass \
| kubectl apply -f -

kustomize build \
  --enable-alpha-plugins \
  --enable-exec \
  calibre-web \
| kubectl apply -f -
